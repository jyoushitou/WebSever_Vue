# ============================================================
# Dockerfile.dev — Vue 3 开发环境容器（支持热更新）
# ============================================================

FROM node:20-alpine

WORKDIR /app

# 安装依赖
COPY package*.json ./
RUN npm install

# 复制源代码（通过 volume 挂载覆盖）
COPY . .

# 启动 Vite 开发服务器
EXPOSE 60907
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "60907"]
